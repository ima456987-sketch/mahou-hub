-- === ユーティリティ関数 ===
local function lookAt(from, to)
    local direction = (to - from).Unit
    local right = direction:Cross(Vector3.new(0, 1, 0))
    local up = right:Cross(direction)
    return CFrame.fromMatrix(from, right, up)
end

local function EnableLoopNoclip()
    if not loopNoclipConnection then
        loopNoclipping = false
        loopNoclipConnection = RunService.Stepped:Connect(function()
            if loopNoclipping == false and Player.Character then
                for _, part in pairs(Player.Character:GetChildren()) do
                    if part:IsA("BasePart") and part.CanCollide and part.Name ~= "floatName" then
                        part.CanCollide = false
                    end
                end
            end
        end)
    end
end

local function DisableLoopNoclip()
    if loopNoclipConnection then
        loopNoclipConnection:Disconnect()
        loopNoclipConnection = nil
    end
    loopNoclipping = true
end

local function SNOWship(part)
    if part and typeof(part) == "Instance" then
        local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
        if root then
            SetNetworkOwner:FireServer(part, lookAt(root.Position, part.Position))
        end
    end
end

local function TeleportPlayerLoop(cf)
    local character = Player.Character
    if character and typeof(cf) == "CFrame" then
        local root = character:FindFirstChild("HumanoidRootPart")
        if root then root.CFrame = cf end
    end
end

local function CreateSkyVelocity(part)
    if not part:FindFirstChild("SkyVelocity") then
        local bv = Instance.new("BodyVelocity", part)
        bv.Name = "SkyVelocity"
        bv.Velocity = Vector3.new(0, 1e12, 0)
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        task.delay(2, function() if bv and bv.Parent then bv:Destroy() end end)
    end
end

local function CheckNetworkOwnership(targetPlayer)
    if typeof(targetPlayer) == "Instance" and targetPlayer:IsA("Player") and targetPlayer.Character then
        local head = targetPlayer.Character:FindFirstChild("Head")
        if head and head:FindFirstChild("PartOwner") and head.PartOwner.Value == Player.Name then
            return true
        end
    end
    return false
end

local function IsValidTarget(targetPlayer)
    if typeof(targetPlayer) == "Instance" and targetPlayer ~= Player then
        if targetPlayer:IsA("Player") and targetPlayer.Character then
            local root = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
            local humanoid = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
            if root and humanoid and humanoid.Health > 0 then return true end
        end
    end
    return false
end

-- === Blobman 関連 (file2より) ===
local BlobmanBeta = {}
function BlobmanBeta.getInv() return workspace:FindFirstChild(Player.Name.."SpawnedInToys") end
function BlobmanBeta.getBlobman()
    local inv = BlobmanBeta.getInv()
    if inv then
        local v = inv:FindFirstChild("CreatureBlobman")
        if v and v:FindFirstChild("VehicleSeat") then return v end
    end
    for _,p in workspace.PlotItems:GetChildren() do
        local m = p:FindFirstChild("CreatureBlobman")
        if m and m:FindFirstChild("PlayerValue") and m.PlayerValue.Value == Player.Name then return m end
    end
end
function BlobmanBeta.spawnBlobman()
    SpawnToyRF:InvokeServer("CreatureBlobman", Player.Character.HumanoidRootPart.CFrame, Vector3.zero)
    task.wait(1)
    return BlobmanBeta.getBlobman()
end
function BlobmanBeta.destroyBlobman()
    local blob = BlobmanBeta.getBlobman()
    if blob then DestroyToy:FireServer(blob) end
end
function BlobmanBeta.ensureSitBlobman()
    local blob = BlobmanBeta.getBlobman()
    if not blob then return end
    local hum = Player.Character:FindFirstChildOfClass("Humanoid")
    if hum and not hum.Sit then blob.VehicleSeat:Sit(hum); task.wait(.5) end
end
function BlobmanBeta.blobGrab(blob,target,side)
    local detector = blob:FindFirstChild(side.."Detector")
    local weld = detector and detector:FindFirstChild(side.."Weld")
    local script = blob:FindFirstChild("BlobmanSeatAndOwnerScript",true)
    local remote = script and script:FindFirstChild("CreatureGrab")
    if remote then remote:FireServer(detector,target,weld) end
end
function BlobmanBeta.blobDrop(blob,target,side)
    local detector = blob:FindFirstChild(side.."Detector")
    local script = blob:FindFirstChild("BlobmanSeatAndOwnerScript",true)
    local remote = script and script:FindFirstChild("CreatureDrop")
    if remote then remote:FireServer(detector,target) end
end
function BlobmanBeta.blobKick(blob,targetRoot,side)
    BlobmanBeta.blobGrab(blob,Player.Character.HumanoidRootPart,side)
    task.wait(.08)
    SetNetworkOwner:FireServer(targetRoot, Player.Character.HumanoidRootPart.CFrame)
    task.wait(.08)
    targetRoot.CFrame += Vector3.new(0,16,0)
    task.wait(.08)
    DestroyGrabLine:FireServer(targetRoot)
    task.wait(.08)
    BlobmanBeta.blobGrab(blob,targetRoot,side)
    task.wait(.08)
    BlobmanBeta.blobDrop(blob,targetRoot,side)
    task.wait(.08)
    DestroyGrabLine:FireServer(targetRoot)
end

-- === キル・引き寄せ・キック機能 ===
local function KillPlayer(targetPlayer)
    if not IsValidTarget(targetPlayer) then return end
    local root = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    local humanoid = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
    local initialPos = Player.Character.HumanoidRootPart.CFrame
    EnableLoopNoclip()
    for i = 1, 30 do
        if not IsValidTarget(targetPlayer) then break end
        SNOWship(root)
        if CheckNetworkOwnership(targetPlayer) or root.AssemblyLinearVelocity.Magnitude > 300 then
            CreateSkyVelocity(root)
            pcall(function() DestroyGrabLine:FireServer(root) end)
            break
        end
        task.wait(0.03)
        TeleportPlayerLoop(root.CFrame * CFrame.new(0, -8, 0))
        humanoid.BreakJointsOnDeath = false
        humanoid:ChangeState(Enum.HumanoidStateType.Dead)
        humanoid.Jump = true
        humanoid.Sit = false
    end
    DisableLoopNoclip()
    TeleportPlayerLoop(initialPos)
end

local function BringPlayer(targetPlayer)
    if not IsValidTarget(targetPlayer) then return end
    local root = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    local humanoid = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
    local initialPos = Player.Character.HumanoidRootPart.CFrame
    local myPos = Player.Character.HumanoidRootPart.Position
    EnableLoopNoclip()
    for i = 1, 30 do
        if not IsValidTarget(targetPlayer) then break end
        SNOWship(root)
        if CheckNetworkOwnership(targetPlayer) then
            root.CFrame = CFrame.new(myPos + Vector3.new(0, 3, 0))
            pcall(function() DestroyGrabLine:FireServer(root) end)
            break
        end
        task.wait(0.03)
        TeleportPlayerLoop(root.CFrame * CFrame.new(0, -8, 0))
        humanoid.Jump = true
        humanoid.Sit = false
    end
    DisableLoopNoclip()
    TeleportPlayerLoop(initialPos)
end

local function KickPlayerLoop(targetPlayer)
    if not IsValidTarget(targetPlayer) then return end
    local root = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    local initialPos = Player.Character.HumanoidRootPart.CFrame
    EnableLoopNoclip()
    for i = 1, 40 do
        if not IsValidTarget(targetPlayer) or not isKicking then break end
        SNOWship(root)
        if CheckNetworkOwnership(targetPlayer) or root.AssemblyLinearVelocity.Magnitude > 300 then
            CreateSkyVelocity(root)
            pcall(function() DestroyGrabLine:FireServer(root) end)
            break
        end
        task.wait(0.03)
        TeleportPlayerLoop(root.CFrame * CFrame.new(0, -8, 0))
    end
    DisableLoopNoclip()
    TeleportPlayerLoop(initialPos)
end

local function UpdateLoopPlayerList()
    local options = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= Player then
            local alreadySelected = false
            for _, selected in ipairs(loopSelectedPlayers) do
                if selected == p.Name then alreadySelected = true break end
            end
            if not alreadySelected then
                table.insert(options, p.Name .. " (" .. p.DisplayName .. ")")
            end
        end
    end
    table.sort(options)
    return options
end

-- === バックグラウンド処理 ===
RunService.Heartbeat:Connect(function()
    pcall(function()
        sethiddenproperty(Player, "SimulationRadius", math.huge)
        local char = Player.Character
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildOfClass("Humanoid")

        if Config.AntiGrab then
            local IsHeld = Player:FindFirstChild("IsHeld")
            if Struggle and IsHeld and IsHeld.Value then
                Struggle:FireServer(Player)
                for _, p in pairs(char:GetChildren()) do if p:IsA("BasePart") then p.Anchored = true end end
            else
                for _, p in pairs(char:GetChildren()) do if p:IsA("BasePart") then p.Anchored = false end end
            end
        end

        if Config.Noclip then
            for _, p in pairs(char:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end
        end

        -- Anti-Kick-Grab
        if Config.AntiKickGrab and root and root:FindFirstChild("FirePlayerPart") then
            local partOwner = root.FirePlayerPart:FindFirstChild("PartOwner")
            if partOwner and partOwner.Value ~= Player.Name then
                RagdollRemote:FireServer(root, 0)
                task.wait(0.1)
                Struggle:FireServer()
            end
        end

        -- Anti-Ragdoll / God Mode
        if (Config.AntiRagdoll or Config.GodMode) and hum then
            hum.PlatformStand = false
            hum.Sit = false
            if hum.Health <= 0 and Config.GodMode then hum.Health = 1 end
        end

        -- Anti-Void
        if Config.AntiVoid and root and root.Position.Y < -800 then
            root.CFrame = CFrame.new(0, 50, 0)
        end

        -- Lag Server (弱, 中, 強) - ビジュアル＆サーバー全体負荷強化版
        if Config.LagServerMode ~= "なし" then
            local count = (Config.LagServerMode == "弱" and 500) or (Config.LagServerMode == "中" and 2500) or (Config.LagServerMode == "強" and 10000) or 0
            for i = 1, count do
                pcall(function()
                    Struggle:FireServer()
                    RagdollRemote:FireServer(root, 0)
                    -- ビジュアルラグ（全員の画面を重くするためのリモート）
                    if i % 10 == 0 then
                        StickyPartEvent:FireServer(root, root.Position, root.CFrame)
                        DestroyGrabLine:FireServer(root)
                    end
                end)
            end
        end

        -- Aura Functions (Fixed Logic with Speed)
        local auraEnabled = Config.KillAura or Config.SkyAura or Config.FlingAura or Config.VoidAura or Config.SpinAura or Config.FreezeAura or Config.RagdollAura
        if auraEnabled and root then
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= Player and p.Character then
                    local pRoot = p.Character:FindFirstChild("HumanoidRootPart") or p.Character:FindFirstChild("Torso")
                    if pRoot and (pRoot.Position - root.Position).Magnitude <= Config.AuraRadius then
                        task.spawn(function()
                            pcall(function()
                                if Config.KillAura then
                                    SetNetworkOwner:FireServer(pRoot, root.CFrame)
                                    p.Character:BreakJoints()
                                end
                                if Config.SkyAura then
                                    SetNetworkOwner:FireServer(pRoot, root.CFrame)
                                    local bv = Instance.new("BodyVelocity", pRoot)
                                    bv.Velocity = Vector3.new(0, 100, 0); bv.MaxForce = Vector3.one * math.huge
                                    game:GetService("Debris"):AddItem(bv, 0.5)
                                end
                                if Config.FlingAura then
                                    SetNetworkOwner:FireServer(pRoot, root.CFrame)
                                    local bv = Instance.new("BodyVelocity", pRoot)
                                    bv.Velocity = Vector3.new(math.random(-1,1)*5e10, 5e15, math.random(-1,1)*5e10)
                                    bv.MaxForce = Vector3.one * math.huge
                                    game:GetService("Debris"):AddItem(bv, 0.5)
                                end
                                if Config.VoidAura then
                                    SetNetworkOwner:FireServer(pRoot, root.CFrame)
                                    for _, part in ipairs(p.Character:GetDescendants()) do if part:IsA("BasePart") then part.CanCollide = false end end
                                    pRoot.Velocity = Vector3.new(0, -1000, 0)
                                end
                                if Config.SpinAura then
                                    SetNetworkOwner:FireServer(pRoot, root.CFrame)
                                    local bav = Instance.new("BodyAngularVelocity", pRoot)
                                    bav.AngularVelocity = Vector3.new(0, 150, 0); bav.MaxTorque = Vector3.one * math.huge
                                    game:GetService("Debris"):AddItem(bav, 0.5)
                                end
                                if Config.FreezeAura then
                                    SetNetworkOwner:FireServer(pRoot, root.CFrame)
                                    pRoot.Anchored = true
                                    task.delay(1, function() if pRoot then pRoot.Anchored = false end end)
                                end
                                if Config.RagdollAura then
                                    RagdollRemote:FireServer(pRoot, 999999)
                                end
                            end)
                        end)
                        if Config.AuraSpeed > 0 then task.wait(Config.AuraSpeed) end
                    end
                end
            end
        end
    end)
end)

task.spawn(function()
    while true do
        task.wait(0.05)
        local char = Player.Character
        -- Anti-Burger
        if Config.AntiBurger and char then
            local root = char:FindFirstChild("HumanoidRootPart")
            if root then
                root.Velocity = Vector3.zero
                local burger = Player.Backpack:FindFirstChild("Hamburger") or char:FindFirstChild("Hamburger")
                if not burger then
                    SpawnToyRF:InvokeServer("Hamburger", root.CFrame, Vector3.zero)
                elseif burger:IsA("Tool") then
                    if burger.Parent == Player.Backpack then burger.Parent = char end
                    burger:Activate()
                end
            end
        end
        -- LoopKill (Self)
        if Config.LoopKill and char and char:FindFirstChild("Humanoid") then char.Humanoid.Health = 0 end
    end
end)

