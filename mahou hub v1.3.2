LoopSection3:AddToggle({
    Name = "選択プレイヤーを引き寄せ",
    Callback = function(v)
        isBringing = v
        if v then task.spawn(function()
            while isBringing do
                for i = #loopSelectedPlayers, 1, -1 do
                    if not isBringing then break end
                    local target = Players:FindFirstChild(loopSelectedPlayers[i])
                    if target then if IsValidTarget(target) then BringPlayer(target) end
                    else table.remove(loopSelectedPlayers, i); UpdateLoopSelectedList() end
                end
                task.wait(0.5)
            end
        end) end
    end
})

LoopSection4:AddToggle({
    Name = "選択プレイヤーをキック",
    Callback = function(v)
        isKicking = v
        if v then task.spawn(function()
            while isKicking do
                for i = #loopSelectedPlayers, 1, -1 do
                    if not isKicking then break end
                    local target = Players:FindFirstChild(loopSelectedPlayers[i])
                    if target then if IsValidTarget(target) then KickPlayerLoop(target) end
                    else table.remove(loopSelectedPlayers, i); UpdateLoopSelectedList() end
                end
                task.wait(0.5)
            end
        end) end
    end
})

-- 6. スパムタブ
local SpamTab = Window:MakeTab({Name = "Chat Spam", Icon = "rbxassetid://4483362458"})
SpamTab:AddTextbox({Name = "メッセージ", Default = Config.SpamMsg, Callback = function(v) Config.SpamMsg = v end})
SpamTab:AddSlider({Name = "間隔 (秒)", Min = 0.1, Max = 10, Default = 1, Callback = function(v) Config.SpamInterval = v end})
SpamTab:AddSlider({Name = "回数", Min = 1, Max = 100, Default = 10, Callback = function(v) Config.SpamCount = v end})
SpamTab:AddButton({Name = "スパム開始", Callback = function() 
    task.spawn(function() 
        for i=1, Config.SpamCount do 
            local channel = game:GetService("TextChatService"):FindFirstChild("TextChannels") and game:GetService("TextChatService").TextChannels:FindFirstChild("RBXGeneral")
            if channel then channel:SendAsync(Config.SpamMsg) 
            else
                local sayMessage = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents") and ReplicatedStorage.DefaultChatSystemChatEvents:FindFirstChild("SayMessageRequest")
                if sayMessage then sayMessage:FireServer(Config.SpamMsg, "All") end
            end
            task.wait(Config.SpamInterval) 
        end 
    end) 
end})

Players.PlayerAdded:Connect(function() task.wait(0.5); LoopPlayerDropdown:Refresh(UpdateLoopPlayerList(), true) end)
Players.PlayerRemoving:Connect(function() task.wait(0.5); LoopPlayerDropdown:Refresh(UpdateLoopPlayerList(), true) end)

