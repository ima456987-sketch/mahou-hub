-- === ユーティリティ関数 ===
local function lookAt(from, to)
    local direction = (to - from).Unit
    local right = direction:Cross(Vector3.new(0, 1, 0))
    local up = right:Cross(direction)
    return CFrame.fromMatrix(from, right, up)
end

local function EnableLoopNoclip()
    if not loopNoclipConnection then
        loopNoclipping = false
        loopNoclipConnection = RunService.Stepped:Connect(function()
            if loopNoclipping == false and Player.Character then
                for _, part in pairs(Player.Character:GetChildren()) do
                    if part:IsA("BasePart") and part.CanCollide and part.Name ~= "floatName" then
                        part.CanCollide = false
                    end
                end
            end
        end)
    end
end

local function DisableLoopNoclip()
    if loopNoclipConnection then
        loopNoclipConnection:Disconnect()
        loopNoclipConnection = nil
    end
    loopNoclipping = true
end

local function SNOWship(part)
    if part and typeof(part) == "Instance" then
        local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
        if root then
            SetNetworkOwner:FireServer(part, lookAt(root.Position, part.Position))
        end
    end
end

local function TeleportPlayerLoop(cf)
    local character = Player.Character
    if character and typeof(cf) == "CFrame" then
        local root = character:FindFirstChild("HumanoidRootPart")
        if root then root.CFrame = cf end
    end
end

local function CreateSkyVelocity(part)
    if not part:FindFirstChild("SkyVelocity") then
        local bv = Instance.new("BodyVelocity", part)
        bv.Name = "SkyVelocity"
        bv.Velocity = Vector3.new(0, 1e12, 0)
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        task.delay(2, function() if bv and bv.Parent then bv:Destroy() end end)
    end
end

local function CheckNetworkOwnership(targetPlayer)
    if typeof(targetPlayer) == "Instance" and targetPlayer:IsA("Player") and targetPlayer.Character then
        local head = targetPlayer.Character:FindFirstChild("Head")
        if head and head:FindFirstChild("PartOwner") and head.PartOwner.Value == Player.Name then
            return true
        end
    end
    return false
end

local function IsValidTarget(targetPlayer)
    if typeof(targetPlayer) == "Instance" and targetPlayer ~= Player then
        if targetPlayer:IsA("Player") and targetPlayer.Character then
            local root = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
            local humanoid = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
            if root and humanoid and humanoid.Health > 0 then return true end
        end
    end
    return false
end

-- === キル・引き寄せ・キック機能 ===
local function KillPlayer(targetPlayer)
    if not IsValidTarget(targetPlayer) then return end
    local root = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    local humanoid = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
    local initialPos = Player.Character.HumanoidRootPart.CFrame
    EnableLoopNoclip()
    for i = 1, 30 do
        if not IsValidTarget(targetPlayer) then break end
        SNOWship(root)
        if CheckNetworkOwnership(targetPlayer) or root.AssemblyLinearVelocity.Magnitude > 300 then
            CreateSkyVelocity(root)
            pcall(function() DestroyGrabLine:FireServer(root) end)
            break
        end
        task.wait(0.03)
        TeleportPlayerLoop(root.CFrame * CFrame.new(0, -8, 0))
        humanoid.BreakJointsOnDeath = false
        humanoid:ChangeState(Enum.HumanoidStateType.Dead)
        humanoid.Jump = true
        humanoid.Sit = false
    end
    DisableLoopNoclip()
    TeleportPlayerLoop(initialPos)
end

local function BringPlayer(targetPlayer)
    if not IsValidTarget(targetPlayer) then return end
    local root = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    local humanoid = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
    local initialPos = Player.Character.HumanoidRootPart.CFrame
    local myPos = Player.Character.HumanoidRootPart.Position
    EnableLoopNoclip()
    for i = 1, 30 do
        if not IsValidTarget(targetPlayer) then break end
        SNOWship(root)
        if CheckNetworkOwnership(targetPlayer) then
            root.CFrame = CFrame.new(myPos + Vector3.new(0, 3, 0))
            pcall(function() DestroyGrabLine:FireServer(root) end)
            break
        end
        task.wait(0.03)
        TeleportPlayerLoop(root.CFrame * CFrame.new(0, -8, 0))
        humanoid.Jump = true
        humanoid.Sit = false
    end
    DisableLoopNoclip()
    TeleportPlayerLoop(initialPos)
end

local function KickPlayerLoop(targetPlayer)
    if not IsValidTarget(targetPlayer) then return end
    local root = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    local initialPos = Player.Character.HumanoidRootPart.CFrame
    EnableLoopNoclip()
    for i = 1, 40 do
        if not IsValidTarget(targetPlayer) or not isKicking then break end
        SNOWship(root)
        if CheckNetworkOwnership(targetPlayer) or root.AssemblyLinearVelocity.Magnitude > 300 then
            CreateSkyVelocity(root)
            pcall(function() DestroyGrabLine:FireServer(root) end)
            break
        end
        task.wait(0.03)
        TeleportPlayerLoop(root.CFrame * CFrame.new(0, -8, 0))
    end
    DisableLoopNoclip()
    TeleportPlayerLoop(initialPos)
end

local function UpdateLoopPlayerList()
    local options = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= Player then
            local alreadySelected = false
            for _, selected in ipairs(loopSelectedPlayers) do
                if selected == p.Name then alreadySelected = true break end
            end
            if not alreadySelected then
                table.insert(options, p.Name .. " (" .. p.DisplayName .. ")")
            end
        end
    end
    table.sort(options)
    return options
end

-- === バックグラウンド・アンチキック処理 ===
RunService.Heartbeat:Connect(function()
    pcall(function()
        sethiddenproperty(Player, "SimulationRadius", math.huge)
        if Config.AntiGrab then
            local char = Player.Character
            local IsHeld = Player:FindFirstChild("IsHeld")
            if char and Struggle and IsHeld and IsHeld.Value then
                Struggle:FireServer(Player)
                for _, p in pairs(char:GetChildren()) do if p:IsA("BasePart") then p.Anchored = true end end
            elseif char then
                for _, p in pairs(char:GetChildren()) do if p:IsA("BasePart") then p.Anchored = false end end
            end
        end
        if Config.Noclip and Player.Character then
            for _, p in pairs(Player.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end
        end
        -- Anti-Kick-Grab
        if Config.AntiKickGrab then
            local char = Player.Character
            if char and char:FindFirstChild("HumanoidRootPart") and char.HumanoidRootPart:FindFirstChild("FirePlayerPart") then
                local partOwner = char.HumanoidRootPart.FirePlayerPart:FindFirstChild("PartOwner")
                if partOwner and partOwner.Value ~= Player.Name then
                    RagdollRemote:FireServer(char.HumanoidRootPart, 0)
                    task.wait(0.1)
                    Struggle:FireServer()
                end
            end
        end
    end)
end)

task.spawn(function()
    while true do
        task.wait(0.05)
        local char = Player.Character
        -- Anti-Burger
        if Config.AntiBurger and char then
            local root = char:FindFirstChild("HumanoidRootPart")
            if root then
                root.Velocity = Vector3.zero
                local burger = Player.Backpack:FindFirstChild("Hamburger") or char:FindFirstChild("Hamburger")
                if not burger then
                    SpawnToyRF:InvokeServer("Hamburger", root.CFrame, Vector3.zero)
                elseif burger:IsA("Tool") then
                    if burger.Parent == Player.Backpack then burger.Parent = char end
                    burger:Activate()
                end
            end
        end
        -- LoopKill (Self)
        if Config.LoopKill and char and char:FindFirstChild("Humanoid") then char.Humanoid.Health = 0 end
    end
end)

-- Anti-Kick V2 (NinjaKunai)
task.spawn(function()
    while true do
        task.wait(0.1)
        if Config.AntiKickV2 then
            pcall(function()
                local char = Player.Character
                local hrp = char:FindFirstChild("HumanoidRootPart")
                local leg = char:FindFirstChild("Right Leg")
                if not hrp or not leg or Player.InPlot.Value then return end
                
                local spawnedToys = workspace:FindFirstChild(Player.Name .. "SpawnedInToys")
                local kunai = spawnedToys and spawnedToys:FindFirstChild("NinjaKunai")
                
                if not kunai and Player.CanSpawnToy.Value then
                    SpawnToyRF:InvokeServer("NinjaKunai", hrp.CFrame, Vector3.zero)
                elseif kunai then
                    local sticky = kunai:WaitForChild("StickyPart", 1)
                    if sticky then
                        local weld = sticky:FindFirstChild("StickyWeld")
                        if not weld or weld.Part1 ~= leg then
                            SetNetworkOwner:FireServer(sticky, sticky.CFrame)
                            StickyPartEvent:FireServer(sticky, leg, CFrame.new(0, 0.5, 0))
                        end
                    end
                end
            end)
        end
    end
end)

