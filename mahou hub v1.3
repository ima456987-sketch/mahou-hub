local function UpdateLoopSelectedList()
    LoopSelectedLabel:Set(#loopSelectedPlayers == 0 and "選択中: なし" or "選択中: " .. table.concat(loopSelectedPlayers, ", "))
end

local LoopPlayerDropdown = LoopSection1:AddDropdown({
    Name = "プレイヤーを選択",
    Default = "",
    Options = UpdateLoopPlayerList(),
    Callback = function(value)
        local playerName = string.split(value, " ")[1]
        if playerName and playerName ~= Player.Name then
            local found = false
            for _, p in ipairs(loopSelectedPlayers) do if p == playerName then found = true break end end
            if not found then table.insert(loopSelectedPlayers, playerName); UpdateLoopSelectedList() end
        end
    end
})

LoopSection1:AddButton({Name = "選択をリセット", Callback = function() loopSelectedPlayers = {}; UpdateLoopSelectedList() end})

LoopSection2:AddToggle({
    Name = "選択プレイヤーをキル",
    Callback = function(v)
        isKilling = v
        if v then task.spawn(function()
            while isKilling do
                for i = #loopSelectedPlayers, 1, -1 do
                    if not isKilling then break end
                    local target = Players:FindFirstChild(loopSelectedPlayers[i])
                    if target then if IsValidTarget(target) then KillPlayer(target) end
                    else table.remove(loopSelectedPlayers, i); UpdateLoopSelectedList() end
                end
                task.wait(0.5)
            end
        end) end
    end
})

