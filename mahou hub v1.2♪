-- 【新規】動画風アニメーション実行ロジック
-- ==========================================
task.spawn(function()
	task.wait(1.0) -- スクリプト読み込み後に少し待機

	-- 1. ロゴが回転しながらふわっと現れる（フェードイン）
	local fadeInInfo = TweenInfo.new(1.0, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
	local fadeIn = TweenService:Create(introLabel, fadeInInfo, {
		TextTransparency = 0,
		Rotation = 0
	})
	fadeIn:Play()
	fadeIn.Completed:Wait() -- フェードイン完了を待つ

	task.wait(1.2) -- 真ん中でロゴを表示し続ける時間

	-- 2. ロゴが消える（フェードアウト）
	local fadeOutInfo = TweenInfo.new(0.6, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
	local fadeOut = TweenService:Create(introLabel, fadeOutInfo, {
		TextTransparency = 1,
		Rotation = 10
	})
	fadeOut:Play()
	fadeOut.Completed:Wait()
	introLabel:Destroy() -- 使い終わったロゴを削除

	-- 3. メインメニューを画面中央へ出現させる（上からスライドイン）
	frame.Visible = true
	local menuInInfo = TweenInfo.new(0.8, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out)
	local slideIn = TweenService:Create(frame, menuInInfo, {
		Position = UDim2.new(0.5, 0, 0.5, 0) -- 完全に画面の中心
	})
	slideIn:Play()
end)
