startSpam.MouseButton1Click:Connect(function()
	if spamming then return end
	spamming = true
	
	local textService = game:GetService("TextChatService")
	local channel = textService and textService:FindFirstChild("TextChannels") and textService.TextChannels:FindFirstChild("RBXGeneral")
	local message = msgInput.Text
	local interval = intervalSlider.getValue()
	local maxCount = countSlider.getValue()
	
	if not channel or message == "" or message == "Input" then
		spamming = false
		return 
	end
	
	task.spawn(function()
		for i = 1, maxCount do
			if not spamming then break end
			pcall(function()
				channel:SendAsync(message)
			end)
			task.wait(interval)
		end
		spamming = false
	end)
end)

stopSpam.MouseButton1Click:Connect(function()
	spamming = false
end)

task.spawn(function()
	while true do
		task.wait()
		local character = player.Character
		if character then
			if loopKillEnabled and character:FindFirstChild("Humanoid") then
				character.Humanoid.Health = 0
			end
			if noclipEnabled then
				for _, part in pairs(character:GetDescendants()) do
					if part:IsA("BasePart") and part.CanCollide then
						part.CanCollide = false
					end
				end
			end
		end
	end
end)

